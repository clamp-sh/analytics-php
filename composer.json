{
    "name": "clamp/analytics",
    "description": "Server-side analytics SDK for Clamp. Send tracked events from PHP apps (Laravel, Symfony, WordPress, etc.).",
    "type": "library",
    "license": "MIT",
    "keywords": ["analytics", "tracking", "events", "clamp", "laravel", "symfony"],
    "homepage": "https://clamp.sh",
    "support": {
        "docs": "https://clamp.sh/docs/sdk/php",
        "source": "https://github.com/clamp-sh/analytics-php",
        "issues": "https://github.com/clamp-sh/analytics-php/issues"
    },
    "require": {
        "php": ">=8.1",
        "ext-curl": "*",
        "ext-json": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^10",
        "phpstan/phpstan": "^1"
    },
    "autoload": {
        "psr-4": {
            "Clamp\\Analytics\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Clamp\\Analytics\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpstan": "phpstan analyse --level=max src tests"
    },
    "minimum-stability": "stable",
    "config": {
        "sort-packages": true
    }
}
